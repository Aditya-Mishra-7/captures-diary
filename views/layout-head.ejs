<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thoughts Vault</title>
    <style>
        :root {
            --bg-color: #121214;
            --surface: #1e1e24;
            --text-main: #e2e2e9;
            --text-muted: #8b8b98;
            --accent: #a3a3ff;
            --danger: #ff8b8b;
        }
        body {
            background: var(--bg-color);
            color: var(--text-main);
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
            margin: 0;
            padding: 2rem 1rem;
        }
        .container { max-width: 680px; margin: 0 auto; }
        header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--text-muted); padding-bottom: 1rem; margin-bottom: 2rem; }
        a { color: var(--accent); text-decoration: none; }
        a:hover { text-decoration: underline; }
        input, textarea, select {
            width: 100%; padding: 0.8rem; background: var(--surface); border: 1px solid #333; color: var(--text-main); margin-bottom: 1rem; box-sizing: border-box; border-radius: 4px; font-family: inherit;
        }
        button { background: var(--accent); color: #000; border: none; padding: 0.7rem 1.5rem; font-weight: bold; cursor: pointer; border-radius: 4px; font-family: inherit;}
        button.text-btn { background: none; color: var(--danger); padding: 0; display: inline; font-weight: normal; }
        .card { background: var(--surface); padding: 1.5rem; border-radius: 6px; margin-bottom: 1.5rem; border: 1px solid #2a2a35; }
        .badge { font-size: 0.75rem; background: #333; padding: 0.2rem 0.5rem; border-radius: 3px; color: var(--accent); }
    </style>
</head>
<body>
<div class="container">